# =============================================================================
# vas-ruthai-deploy — Merged VAS + Ruth AI deployment
# =============================================================================
# Copy this file to .env and fill in the values marked REQUIRED.
# Do NOT commit .env — it contains secrets.
#
# This file is the union of vas-ms-v2/deploy/.env.example and Ruth AI's
# environment. The merged compose imports VAS service definitions from
# ../vas-ms-v2/deploy/docker-compose.yml, so any var that VAS reads must
# also be set here.
# =============================================================================

# ── REQUIRED: VAS host networking ──────────────────────────────────────────
# IP address of this host as reachable by browser clients on the LAN.
# WebRTC ICE candidates will advertise this address. Using "localhost"
# breaks remote viewers — they need an IP they can actually reach.
# Example: 10.40.128.10
#
# This is the SINGLE operator-facing host-IP variable for the merged
# deployment. docker-compose.yml maps it into VAS's internal
# MEDIASOUP_ANNOUNCED_IP for the mediasoup container, and the
# VAS_WEBRTC_URL below interpolates it for the Ruth frontend. VAS
# standalone (vas-ms-v2/deploy/) keeps using MEDIASOUP_ANNOUNCED_IP
# as its own var — that path is unchanged.
HOST_IP=

# ── REQUIRED: VAS secrets ──────────────────────────────────────────────────
VAS_DB_PASSWORD=
VAS_API_KEY=
VAS_JWT_SECRET=

# ── REQUIRED: Ruth AI secrets ──────────────────────────────────────────────
RUTH_POSTGRES_PASSWORD=
RUTH_JWT_SECRET=

# Service-to-service auth: Ruth AI talks to VAS as this client.
#
# This is the VAS<->Ruth credential contract — set ONCE here. The
# integration docker-compose maps the same value to both services:
#   - VAS receives it as VAS_RUTH_CLIENT_SECRET and seeds the
#     ruth-ai-backend OAuth client at startup (seed_ruth_client()
#     in vas-ms-v2/backend/main.py). No manual
#     POST /v2/auth/clients step.
#   - Ruth reads it as VAS_CLIENT_SECRET to authenticate.
# Generate with: openssl rand -hex 32
VAS_CLIENT_ID=ruth-ai-backend
VAS_CLIENT_SECRET=

# ── Optional: VAS storage ──────────────────────────────────────────────────
STORAGE_ROOT=/mnt/storage
VAS_HOT_RETENTION_DAYS=7
VAS_COLD_RETENTION_DAYS=90

# ── Optional: VAS video encoder (CPU vs GPU) ──────────────────────────────
# Selects the ffmpeg encoder used on the WebRTC re-encode path:
#   h264_nvenc — GPU NVENC; requires the GPU compose overlay
#   libx264    — CPU software encoder; no GPU device needed
# Validated at VAS backend startup; an unknown value fails fast.
#
# Pairing rule (must match — backend fails fast on mismatch):
#   GPU mode (project server, NVIDIA host):
#     VAS_VIDEO_CODEC=h264_nvenc
#     docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d
#   CPU mode (MCU appliance, no GPU for VAS):
#     VAS_VIDEO_CODEC=libx264
#     docker compose up -d
#
# The base docker-compose.yml is CPU-safe (no GPU reservation). The
# GPU overlay (docker-compose.gpu.yml) adds runtime: nvidia, the
# NVIDIA_VISIBLE_DEVICES env, and the deploy.resources GPU reservation.
VAS_VIDEO_CODEC=h264_nvenc

# Index of the NVIDIA GPU used by ffmpeg nvenc for the WebRTC re-encode path.
# Run `nvidia-smi` to see indices. Default 1 to leave GPU 0 for AI workloads.
# Only relevant when the GPU overlay is in play.
NVENC_GPU_INDEX=1

# ── Optional: VAS ports ────────────────────────────────────────────────────
VAS_HTTP_PORT=8086
VAS_BACKEND_PORT=8085
VAS_FRONTEND_HOST_PORT=3200
MEDIASOUP_PORT=3001
VAS_DB_HOST_PORT=5433
VAS_REDIS_HOST_PORT=6380
MEDIASOUP_RTC_MIN_PORT=20000
MEDIASOUP_RTC_MAX_PORT=20999

# ── Optional: VAS db identifiers ───────────────────────────────────────────
VAS_DB_USER=vas
VAS_DB_NAME=vas_db

# ── Optional: VAS feature flags ────────────────────────────────────────────
VAS_BACKUP_ENABLED=false

# ── Optional: Ruth AI ──────────────────────────────────────────────────────
RUTH_AI_ENV=development
RUTH_AI_LOG_LEVEL=info
RUTH_POSTGRES_USER=ruth
RUTH_POSTGRES_DB=ruth_ai

# Host port the Ruth AI frontend (nginx) is exposed on. Default 80
# gives a clean customer-facing URL (http://<host>/ with no :port
# suffix) — important for appliances like the MCU. Override if
# port 80 is already taken on the host (e.g. set to 3300 if you're
# running this alongside something else listening on :80).
#
# Note: binding host port 80 requires the Docker daemon to be able
# to bind privileged ports. Standard rootful Docker can; rootless
# Docker needs `sysctl net.ipv4.ip_unprivileged_port_start=80` or
# a port >= 1024.
RUTH_FRONTEND_HOST_PORT=80

# Ruth AI frontend's WebRTC URL — the operator-facing host:port for the
# MediaSoup server. With the nginx-on-:8086 cutover, set this to
# ws://<host>:<VAS_HTTP_PORT>/ws/mediasoup if Ruth AI ever switches to
# routing through nginx; for now it points directly at MediaSoup.
VAS_WEBRTC_URL=ws://${HOST_IP}:3002

# Optional Ruth AI tuning
NLP_CHAT_TIMEOUT_SECONDS=120
UNIFIED_RUNTIME_TIMEOUT=30.0
