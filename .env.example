# =============================================================================
# vas-ruthai-deploy — Merged VAS + Ruth AI deployment
# =============================================================================
# Copy this file to .env and fill in the values marked REQUIRED.
# Do NOT commit .env — it contains secrets.
#
# This file is the union of vas-ms-v2/deploy/.env.example and Ruth AI's
# environment. The merged compose imports VAS service definitions from
# ../vas-ms-v2/deploy/docker-compose.yml, so any var that VAS reads must
# also be set here.
# =============================================================================

# ── REQUIRED: VAS host networking ──────────────────────────────────────────
# IP address of this host as reachable by browser clients on the LAN.
# WebRTC ICE candidates will advertise this address. Using "localhost"
# breaks remote viewers — they need an IP they can actually reach.
# Example: 10.40.128.10
MEDIASOUP_ANNOUNCED_IP=

# Used as the legacy-name alias for the same value (Ruth AI services
# reference HOST_IP in older configs). Keep these two equal.
HOST_IP=

# ── REQUIRED: VAS secrets ──────────────────────────────────────────────────
VAS_DB_PASSWORD=
VAS_API_KEY=
VAS_JWT_SECRET=

# ── REQUIRED: Ruth AI secrets ──────────────────────────────────────────────
RUTH_POSTGRES_PASSWORD=
RUTH_JWT_SECRET=

# Service-to-service auth: Ruth AI talks to VAS as this client
VAS_CLIENT_ID=ruth-ai-backend
VAS_CLIENT_SECRET=

# ── Optional: VAS storage / GPU ────────────────────────────────────────────
STORAGE_ROOT=/mnt/storage
NVENC_GPU_INDEX=1
VAS_HOT_RETENTION_DAYS=7
VAS_COLD_RETENTION_DAYS=90

# ── Optional: VAS ports ────────────────────────────────────────────────────
VAS_HTTP_PORT=8086
VAS_BACKEND_PORT=8085
VAS_FRONTEND_HOST_PORT=3200
MEDIASOUP_PORT=3001
VAS_DB_HOST_PORT=5433
VAS_REDIS_HOST_PORT=6380
MEDIASOUP_RTC_MIN_PORT=20000
MEDIASOUP_RTC_MAX_PORT=20999

# ── Optional: VAS db identifiers ───────────────────────────────────────────
VAS_DB_USER=vas
VAS_DB_NAME=vas_db

# ── Optional: VAS feature flags ────────────────────────────────────────────
VAS_BACKUP_ENABLED=false

# ── Optional: Ruth AI ──────────────────────────────────────────────────────
RUTH_AI_ENV=development
RUTH_AI_LOG_LEVEL=info
RUTH_POSTGRES_USER=ruth
RUTH_POSTGRES_DB=ruth_ai

# Ruth AI frontend's WebRTC URL — the operator-facing host:port for the
# MediaSoup server. With the nginx-on-:8086 cutover, set this to
# ws://<host>:<VAS_HTTP_PORT>/ws/mediasoup if Ruth AI ever switches to
# routing through nginx; for now it points directly at MediaSoup.
VAS_WEBRTC_URL=ws://${HOST_IP}:3002

# Optional Ruth AI tuning
NLP_CHAT_TIMEOUT_SECONDS=120
UNIFIED_RUNTIME_TIMEOUT=30.0
